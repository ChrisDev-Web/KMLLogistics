@model E1___Sosa_Morales.Models.Estadisticas.EstadisticasViewModel
@using System.Text.Json
@{
    Layout = "_DashboardLayout";
    ViewBag.PageTitle = "Estadísticas";
    ViewBag.SidebarActive = Model.Module.SidebarActive;
    var dash = Model.Dashboard;
    var s = dash?.Summary;
    var c = dash?.Comparison;
    var periodLabel = dash?.Period?.Label ?? "Últimos 30 días";
    var activePreset = dash?.Period?.Preset ?? "last30";
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    string Fmt(decimal v) => v.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-PE"));
    var netFlow = (s?.TotalSales ?? 0) - (s?.TotalPurchases ?? 0);
}

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/Public/CSS/Estadisticas/estadisticas.css")" asp-append-version="true" />
}

<partial name="_ModuleTabs" model="Model.Module" />

<div class="dash" id="statsRoot">
    <header class="dash__head">
        <div>
            <h1 class="dash__title">Dashboard</h1>
            <p class="dash__subtitle">Resumen general de la gestión del negocio</p>
        </div>
        <div class="dash__filters">
            <div class="dash__presets" id="statsPresets">
                <button type="button" class="dash-pill @(activePreset == "today" ? "active" : "")" data-preset="today">Hoy</button>
                <button type="button" class="dash-pill @(activePreset == "last30" ? "active" : "")" data-preset="last30">30 días</button>
                <button type="button" class="dash-pill @(activePreset == "month" ? "active" : "")" data-preset="month">Mes actual</button>
                <button type="button" class="dash-pill @(activePreset == "custom" ? "active" : "")" data-preset="custom">Rango</button>
            </div>
            <div class="dash__range" id="statsCustomRange" hidden>
                <input type="date" id="statsDateFrom" />
                <span>—</span>
                <input type="date" id="statsDateTo" />
                <button type="button" class="dash-btn" id="statsApplyRange">Aplicar</button>
            </div>
            <span class="dash__period" id="statsPeriodBadge">@periodLabel</span>
        </div>
    </header>

    <div class="dash__kpis" id="statsKpis">
        <article class="dash-kpi dash-kpi--green">
            <div class="dash-kpi__top">
                <div class="dash-kpi__icon"><i class="bi bi-graph-up-arrow"></i></div>
                <span class="dash-kpi__badge" id="kpiBadgeSales">—</span>
            </div>
            <span class="dash-kpi__label">Ingresos por ventas</span>
            <span class="dash-kpi__hint">Facturación del período</span>
            <strong class="dash-kpi__value" id="kpiTotalSales">S/ @Fmt(s?.TotalSales ?? 0)</strong>
            <canvas class="dash-kpi__spark" id="sparkSales" height="40"></canvas>
        </article>
        <article class="dash-kpi dash-kpi--orange">
            <div class="dash-kpi__top">
                <div class="dash-kpi__icon"><i class="bi bi-bag-check"></i></div>
                <span class="dash-kpi__badge" id="kpiBadgePurchases">—</span>
            </div>
            <span class="dash-kpi__label">Egresos por compras</span>
            <span class="dash-kpi__hint">Compras completadas en el rango</span>
            <strong class="dash-kpi__value" id="kpiTotalPurchases">S/ @Fmt(s?.TotalPurchases ?? 0)</strong>
            <canvas class="dash-kpi__spark" id="sparkPurchases" height="40"></canvas>
        </article>
        <article class="dash-kpi dash-kpi--blue">
            <div class="dash-kpi__top">
                <div class="dash-kpi__icon"><i class="bi bi-cash-stack"></i></div>
                <span class="dash-kpi__badge" id="kpiBadgeFlow">—</span>
            </div>
            <span class="dash-kpi__label">Flujo neto</span>
            <span class="dash-kpi__hint">Ingresos − egresos</span>
            <strong class="dash-kpi__value" id="kpiNetBalance">S/ @Fmt(netFlow)</strong>
            <canvas class="dash-kpi__spark" id="sparkFlow" height="40"></canvas>
        </article>
        <article class="dash-kpi dash-kpi--purple">
            <div class="dash-kpi__top">
                <div class="dash-kpi__icon"><i class="bi bi-piggy-bank"></i></div>
                <span class="dash-kpi__badge" id="kpiBadgeProfit">—</span>
            </div>
            <span class="dash-kpi__label">Ganancia neta</span>
            <span class="dash-kpi__hint">Margen sobre costo de producto</span>
            <strong class="dash-kpi__value" id="kpiNetProfit">S/ @Fmt(s?.NetProfit ?? 0)</strong>
            <canvas class="dash-kpi__spark" id="sparkProfit" height="40"></canvas>
        </article>
    </div>

    <div class="dash__grid" id="statsCharts">
        <section class="dash-card dash-card--8">
            <header class="dash-card__head">
                <div>
                    <h2>Evolución de ventas, compras y ganancia</h2>
                    <p id="trendChartSubtitle">Historial operativo del período</p>
                </div>
                <div class="dash-series" id="seriesToggles">
                    <button type="button" class="dash-series__btn active" data-series="all">Todo</button>
                    <button type="button" class="dash-series__btn" data-series="sales">Ventas</button>
                    <button type="button" class="dash-series__btn" data-series="purchases">Compras</button>
                    <button type="button" class="dash-series__btn" data-series="profit">Ganancia</button>
                </div>
            </header>
            <div class="dash-card__canvas dash-card__canvas--lg"><canvas id="chartTrend"></canvas></div>
        </section>

        <section class="dash-card dash-card--4">
            <header class="dash-card__head">
                <div>
                    <h2>Composición del flujo</h2>
                    <p>Ingresos vs egresos del período</p>
                </div>
            </header>
            <div class="dash-donut-wrap">
                <div class="dash-card__canvas dash-card__canvas--donut"><canvas id="chartFlow"></canvas></div>
                <div class="dash-donut-center" id="flowCenter">S/ 0.00</div>
            </div>
            <ul class="dash-legend" id="flowLegend"></ul>
        </section>

        <section class="dash-card dash-card--4">
            <header class="dash-card__head">
                <div>
                    <h2>Ventas por método de pago</h2>
                    <p>Distribución de cobros</p>
                </div>
            </header>
            <div class="dash-donut-wrap">
                <div class="dash-card__canvas dash-card__canvas--donut"><canvas id="chartPayments"></canvas></div>
                <div class="dash-donut-center dash-donut-center--sm" id="paymentCenter">S/ 0.00</div>
            </div>
            <ul class="dash-legend" id="paymentLegend"></ul>
        </section>

        <section class="dash-card dash-card--4">
            <header class="dash-card__head">
                <div>
                    <h2>Ingresos y egresos por hora</h2>
                    <p>Actividad del período</p>
                </div>
            </header>
            <div class="dash-card__canvas"><canvas id="chartHourly"></canvas></div>
        </section>

        <section class="dash-card dash-card--4">
            <header class="dash-card__head">
                <div>
                    <h2>Resultado operativo</h2>
                    <p>Ventas, compras y balance</p>
                </div>
            </header>
            <div class="dash-card__canvas"><canvas id="chartResult"></canvas></div>
        </section>

        <section class="dash-card dash-card--4">
            <header class="dash-card__head">
                <div>
                    <h2>Top categorías por ventas</h2>
                    <p>Participación por categoría</p>
                </div>
            </header>
            <div class="dash-bars" id="categoryBars"></div>
        </section>

        <section class="dash-card dash-card--8">
            <header class="dash-card__head">
                <div>
                    <h2>Top productos vendidos</h2>
                    <p>Ranking por ingresos</p>
                </div>
            </header>
            <div class="dash-card__canvas dash-card__canvas--md"><canvas id="chartProducts"></canvas></div>
        </section>

        <section class="dash-card dash-card--6">
            <header class="dash-card__head">
                <div>
                    <h2>Alertas de stock</h2>
                    <p>Productos con stock bajo (≤ 10 u.)</p>
                </div>
            </header>
            <div class="dash-table-wrap">
                <table class="dash-table">
                    <thead><tr><th>Producto</th><th>Almacén</th><th>Stock</th><th>Estado</th></tr></thead>
                    <tbody id="stockAlertsBody"></tbody>
                </table>
            </div>
        </section>

        <section class="dash-card dash-card--6">
            <header class="dash-card__head">
                <div>
                    <h2>Últimas ventas</h2>
                    <p>Transacciones del período</p>
                </div>
            </header>
            <div class="dash-table-wrap">
                <table class="dash-table">
                    <thead><tr><th>Fecha</th><th>Cliente</th><th>Pago</th><th>Total</th></tr></thead>
                    <tbody id="recentSalesBody"></tbody>
                </table>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        window.statsConfig = {
            dataUrl: '@Url.Action("Data", "Estadisticas")',
            initialData: @Html.Raw(JsonSerializer.Serialize(dash, jsonOptions))
        };
    </script>
    <script src="@Url.Content("~/Public/JS/Estadisticas/estadisticas.js")" asp-append-version="true"></script>
}
