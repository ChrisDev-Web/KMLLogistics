@model E1___Sosa_Morales.Models.Users.LoginViewModel
@{
    Layout = "~/Views/Login/_Layout.cshtml";
    ViewData["Title"] = "Iniciar sesión";
}

<div class="auth-card">
    <h1 class="auth-card__title">Iniciar sesión</h1>
    <p class="auth-card__subtitle">Accede al panel administrativo.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="auth-success">@TempData["SuccessMessage"]</div>
    }

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
    {
        <div class="auth-error">
            @Html.ValidationSummary(excludePropertyErrors: true)
        </div>
    }

    <form asp-controller="Login" asp-action="Index" method="post">
        @Html.AntiForgeryToken()

        <div class="auth-field">
            <label asp-for="Username">Usuario</label>
            <div class="auth-input-wrap">
                <i class="bi bi-person"></i>
                <input asp-for="Username" placeholder="Usuario" />
            </div>
            <span asp-validation-for="Username" class="field-error"></span>
        </div>

        <div class="auth-field">
            <label asp-for="Password">Contraseña</label>
            <div class="auth-input-wrap">
                <i class="bi bi-lock"></i>
                <input asp-for="Password" placeholder="Ingresa tu contraseña" />
            </div>
            <span asp-validation-for="Password" class="field-error"></span>
        </div>

        <button type="submit" class="auth-btn">
            <i class="bi bi-box-arrow-in-right"></i>
            Iniciar sesión
        </button>
    </form>

    <div class="auth-footer">
        ¿No tienes cuenta? <a asp-controller="Register" asp-action="Index">Regístrate</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
