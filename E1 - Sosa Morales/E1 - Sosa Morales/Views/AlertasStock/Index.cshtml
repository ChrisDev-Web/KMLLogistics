@model E1___Sosa_Morales.Models.AlertasStock.AlertasStockViewModel
@{
    Layout = "_DashboardLayout";
    ViewBag.PageTitle = "Alertas de stock";
    ViewBag.SidebarActive = "dashboard";
    var f = Model.Filter;
    var s = Model.Summary;
    var hasAdvancedFilters = f.IdProduct.HasValue || f.IdWarehouse.HasValue;
}

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/Public/CSS/AlertasStock/alertas-stock.css")" asp-append-version="true" />
}

<div class="alerts-page">
    <div class="alerts-page__header">
        <div>
            <h1 class="alerts-page__title">Alertas</h1>
            <p class="alerts-page__subtitle">Centro de notificaciones y alertas de stock del sistema</p>
        </div>
        <div class="alerts-page__header-actions">
            <button type="button" class="alerts-btn alerts-btn--outline" id="toggleFiltersBtn" aria-expanded="@(hasAdvancedFilters ? "true" : "false")">
                <i class="bi bi-funnel"></i>
                Filtros
            </button>
            <a asp-controller="Dashboard" asp-action="Index" class="alerts-btn alerts-btn--back">
                <i class="bi bi-arrow-left"></i>
                Volver al Dashboard
            </a>
        </div>
    </div>

    <div class="alerts-kpi-grid">
        <div class="alerts-kpi alerts-kpi--critical">
            <div class="alerts-kpi__icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <div class="alerts-kpi__body">
                <span class="alerts-kpi__label">Activas</span>
                <span class="alerts-kpi__count" id="kpiActive">@s.ActiveCount</span>
                <span class="alerts-kpi__hint">Stock bajo — requieren atención</span>
            </div>
            <span class="alerts-kpi__bar"></span>
        </div>
        <div class="alerts-kpi alerts-kpi--warning">
            <div class="alerts-kpi__icon"><i class="bi bi-bell-fill"></i></div>
            <div class="alerts-kpi__body">
                <span class="alerts-kpi__label">Reenviadas</span>
                <span class="alerts-kpi__count">@s.HighNotifyCount</span>
                <span class="alerts-kpi__hint">Más de un aviso sin reponer</span>
            </div>
            <span class="alerts-kpi__bar"></span>
        </div>
        <div class="alerts-kpi alerts-kpi--resolved">
            <div class="alerts-kpi__icon"><i class="bi bi-check-circle-fill"></i></div>
            <div class="alerts-kpi__body">
                <span class="alerts-kpi__label">Resueltas</span>
                <span class="alerts-kpi__count">@s.ResolvedCount</span>
                <span class="alerts-kpi__hint">Stock repuesto</span>
            </div>
            <span class="alerts-kpi__bar"></span>
        </div>
        <div class="alerts-kpi alerts-kpi--total">
            <div class="alerts-kpi__icon"><i class="bi bi-bell"></i></div>
            <div class="alerts-kpi__body">
                <span class="alerts-kpi__label">Total alertas</span>
                <span class="alerts-kpi__count">@s.TotalCount</span>
                <span class="alerts-kpi__hint">Registros en el sistema</span>
            </div>
            <span class="alerts-kpi__bar"></span>
        </div>
    </div>

    <div class="alerts-panel">
        <div class="alerts-panel__tabs">
            <a asp-controller="AlertasStock" asp-action="Index"
               asp-route-search="@f.Search" asp-route-idProduct="@f.IdProduct" asp-route-idWarehouse="@f.IdWarehouse"
               asp-route-status="ALL"
               class="alerts-tab @(f.Status == "ALL" ? "active" : "")">
                Todas <span class="alerts-tab__count">(@s.TotalCount)</span>
            </a>
            <a asp-controller="AlertasStock" asp-action="Index"
               asp-route-search="@f.Search" asp-route-idProduct="@f.IdProduct" asp-route-idWarehouse="@f.IdWarehouse"
               asp-route-status="ACTIVE"
               class="alerts-tab @(f.Status == "ACTIVE" ? "active" : "")">
                Activas <span class="alerts-tab__count">(@s.ActiveCount)</span>
            </a>
            <a asp-controller="AlertasStock" asp-action="Index"
               asp-route-search="@f.Search" asp-route-idProduct="@f.IdProduct" asp-route-idWarehouse="@f.IdWarehouse"
               asp-route-status="RESOLVED"
               class="alerts-tab @(f.Status == "RESOLVED" ? "active" : "")">
                Resueltas <span class="alerts-tab__count">(@s.ResolvedCount)</span>
            </a>
        </div>

        <form method="get" asp-controller="AlertasStock" asp-action="Index" id="alertsFilterForm" class="alerts-panel__filters @(hasAdvancedFilters ? "is-open" : "")">
            <input type="hidden" name="status" value="@f.Status" />
            <div class="alerts-panel__filters-grid">
                <div class="alerts-field">
                    <label for="idProduct">Producto</label>
                    <select id="idProduct" name="idProduct">
                        <option value="">Todos los productos</option>
                        @foreach (var product in Model.Products)
                        {
                            if (f.IdProduct == product.Id)
                            {
                                <option value="@product.Id" selected>@product.Name</option>
                            }
                            else
                            {
                                <option value="@product.Id">@product.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="alerts-field">
                    <label for="idWarehouse">Almacén</label>
                    <select id="idWarehouse" name="idWarehouse">
                        <option value="">Todos los almacenes</option>
                        @foreach (var warehouse in Model.Warehouses)
                        {
                            if (f.IdWarehouse == warehouse.Id)
                            {
                                <option value="@warehouse.Id" selected>@warehouse.Name</option>
                            }
                            else
                            {
                                <option value="@warehouse.Id">@warehouse.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="alerts-field alerts-field--actions">
                    <button type="submit" class="alerts-btn alerts-btn--primary">
                        <i class="bi bi-funnel"></i> Aplicar filtros
                    </button>
                    <a asp-controller="AlertasStock" asp-action="Index" asp-route-status="@f.Status" class="alerts-btn alerts-btn--ghost">
                        Limpiar
                    </a>
                </div>
            </div>
        </form>

        <form method="get" asp-controller="AlertasStock" asp-action="Index" class="alerts-panel__toolbar">
            <input type="hidden" name="status" value="@f.Status" />
            <input type="hidden" name="idProduct" value="@f.IdProduct" />
            <input type="hidden" name="idWarehouse" value="@f.IdWarehouse" />
            <div class="alerts-search">
                <i class="bi bi-search"></i>
                <input type="text" name="search" value="@f.Search" placeholder="Buscar alerta..." />
            </div>
            <button type="submit" class="alerts-btn alerts-btn--primary alerts-btn--sm">Buscar</button>
        </form>

        @Html.AntiForgeryToken()
        <div id="alertsToast" class="alerts-toast" role="status" aria-live="polite"></div>

        <div class="alerts-table-wrap">
            <table id="alertsTable" class="alerts-table display">
                <thead>
                    <tr>
                        <th>Alerta</th>
                        <th>Almacén</th>
                        <th>Nivel</th>
                        <th>Fecha y hora</th>
                        <th>Estado</th>
                        <th>Envíos</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Alerts.Count == 0)
                    {
                        <tr class="alerts-table__empty-row">
                            <td colspan="7">No se encontraron alertas con los filtros seleccionados.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var alert in Model.Alerts)
                        {
                            <tr data-alert-id="@alert.IdStockAlert" class="@(alert.IsActive ? "row-active" : "row-resolved")">
                                <td>
                                    <div class="alert-cell">
                                        <span class="alert-cell__icon @(alert.IsActive ? "alert-cell__icon--critical" : "alert-cell__icon--resolved")">
                                            <i class="bi @(alert.IsActive ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i>
                                        </span>
                                        <div>
                                            <span class="alert-cell__title">@alert.ProductName</span>
                                            <span class="alert-cell__meta">
                                                Stock @alert.Stock / Mín. @alert.MinStock
                                                @if (alert.StockDeficit > 0)
                                                {
                                                    <text> · Faltan @alert.StockDeficit un.</text>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(alert.Location))
                                                {
                                                    <text> · @alert.Location</text>
                                                }
                                            </span>
                                        </div>
                                    </div>
                                </td>
                                <td>@alert.WarehouseName</td>
                                <td>
                                    <span class="level-badge @(alert.IsActive ? "level-badge--critical" : "level-badge--resolved")">
                                        @(alert.IsActive ? "Crítica" : "Resuelta")
                                    </span>
                                </td>
                                <td data-order="@alert.LastNotifiedAt.Ticks" class="cell-last-notified">
                                    <span class="date-cell__date">@alert.LastNotifiedAt.ToString("dd/MM/yyyy")</span>
                                    <span class="date-cell__time">@alert.LastNotifiedAt.ToString("hh:mm tt")</span>
                                </td>
                                <td>
                                    <span class="state-text @(alert.IsActive ? "state-text--active" : "state-text--resolved")">
                                        @(alert.IsActive ? "Activa" : "Resuelta")
                                    </span>
                                </td>
                                <td class="cell-notification-count">@alert.NotificationCount</td>
                                <td>
                                    <div class="alerts-actions">
                                        @if (alert.IsActive)
                                        {
                                            <button type="button"
                                                    class="alerts-action-btn btn-resend-alert"
                                                    data-alert-id="@alert.IdStockAlert"
                                                    title="Reenviar alerta">
                                                <i class="bi bi-send"></i>
                                            </button>
                                        }
                                        <span class="alerts-action-hint" title="@(alert.LastSentByUsername ?? "Sistema")">
                                            <i class="bi bi-person"></i>
                                        </span>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.alertasStockConfig = {
            resendUrl: '@Url.Action("Resend", "AlertasStock")',
            hasData: @(Model.Alerts.Count > 0 ? "true" : "false")
        };
    </script>
    <script src="@Url.Content("~/Public/JS/AlertasStock/alertas-stock.js")" asp-append-version="true"></script>
}
