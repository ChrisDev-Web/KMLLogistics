@model E1___Sosa_Morales.Models.AlertasStock.AlertasStockViewModel
@{
    Layout = "_DashboardLayout";
    ViewBag.PageTitle = "Alertas del sistema";
    ViewBag.SidebarActive = "dashboard";
    var f = Model.Filter;
    var s = Model.Summary;
}

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/Public/CSS/AlertasStock/alertas-stock.css")" asp-append-version="true" />
}

<div class="alerts-page" id="alertsPageRoot" data-status="@f.Status">
    <div class="alerts-page__header">
        <div>
            <h1 class="alerts-page__title">Alertas</h1>
            <p class="alerts-page__subtitle">Stock bajo, vehículos en regreso y disponibilidad logística</p>
        </div>
        <div class="alerts-page__header-actions">
            <a asp-controller="Dashboard" asp-action="Index" class="alerts-btn alerts-btn--back">
                <i class="bi bi-arrow-left"></i>
                Volver al Dashboard
            </a>
        </div>
    </div>

    <div class="alerts-kpi-grid">
        <div class="alerts-kpi alerts-kpi--critical">
            <div class="alerts-kpi__icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <div class="alerts-kpi__body">
                <span class="alerts-kpi__label">Activas</span>
                <span class="alerts-kpi__count" id="kpiActive">@s.ActiveCount</span>
                <span class="alerts-kpi__hint">Stock y logística pendientes</span>
            </div>
            <span class="alerts-kpi__bar"></span>
        </div>
        <div class="alerts-kpi alerts-kpi--warning">
            <div class="alerts-kpi__icon"><i class="bi bi-bell-fill"></i></div>
            <div class="alerts-kpi__body">
                <span class="alerts-kpi__label">Reenviadas</span>
                <span class="alerts-kpi__count" id="kpiHighNotify">@s.HighNotifyCount</span>
                <span class="alerts-kpi__hint">Más de un aviso sin resolver</span>
            </div>
            <span class="alerts-kpi__bar"></span>
        </div>
        <div class="alerts-kpi alerts-kpi--resolved">
            <div class="alerts-kpi__icon"><i class="bi bi-check-circle-fill"></i></div>
            <div class="alerts-kpi__body">
                <span class="alerts-kpi__label">Resueltas</span>
                <span class="alerts-kpi__count" id="kpiResolved">@s.ResolvedCount</span>
                <span class="alerts-kpi__hint">Atendidas o repuestas</span>
            </div>
            <span class="alerts-kpi__bar"></span>
        </div>
        <div class="alerts-kpi alerts-kpi--total">
            <div class="alerts-kpi__icon"><i class="bi bi-bell"></i></div>
            <div class="alerts-kpi__body">
                <span class="alerts-kpi__label">Total alertas</span>
                <span class="alerts-kpi__count" id="kpiTotal">@s.TotalCount</span>
                <span class="alerts-kpi__hint">Registros en el sistema</span>
            </div>
            <span class="alerts-kpi__bar"></span>
        </div>
    </div>

    <div class="alerts-panel">
        <div class="alerts-panel__tabs" id="alertsTabs">
            <button type="button" class="alerts-tab @(f.Status == "ALL" ? "active" : "")" data-status="ALL">
                Todas <span class="alerts-tab__count" id="tabCountAll">(@s.TotalCount)</span>
            </button>
            <button type="button" class="alerts-tab @(f.Status == "ACTIVE" ? "active" : "")" data-status="ACTIVE">
                Activas <span class="alerts-tab__count" id="tabCountActive">(@s.ActiveCount)</span>
            </button>
            <button type="button" class="alerts-tab @(f.Status == "RESOLVED" ? "active" : "")" data-status="RESOLVED">
                Resueltas <span class="alerts-tab__count" id="tabCountResolved">(@s.ResolvedCount)</span>
            </button>
        </div>

        <div class="alerts-panel__filters" id="alertsFilterForm">
            <div class="alerts-panel__filters-grid">
                <div class="alerts-field">
                    <label for="idProduct">Producto</label>
                    <select id="idProduct" name="idProduct">
                        <option value="">Todos los productos</option>
                        @foreach (var product in Model.Products)
                        {
                            if (f.IdProduct == product.Id)
                            {
                                <option value="@product.Id" selected>@product.Name</option>
                            }
                            else
                            {
                                <option value="@product.Id">@product.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="alerts-field">
                    <label for="idWarehouse">Almacén</label>
                    <select id="idWarehouse" name="idWarehouse">
                        <option value="">Todos los almacenes</option>
                        @foreach (var warehouse in Model.Warehouses)
                        {
                            if (f.IdWarehouse == warehouse.Id)
                            {
                                <option value="@warehouse.Id" selected>@warehouse.Name</option>
                            }
                            else
                            {
                                <option value="@warehouse.Id">@warehouse.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="alerts-field">
                    <label for="search">Buscar</label>
                    <div class="alerts-search">
                        <i class="bi bi-search"></i>
                        <input type="text" id="search" name="search" value="@f.Search" placeholder="Buscar alerta..." autocomplete="off" />
                    </div>
                </div>
                <div class="alerts-field alerts-field--actions">
                    <button type="button" class="alerts-btn alerts-btn--ghost" id="alertsClearBtn">Limpiar</button>
                </div>
            </div>
        </div>

        @Html.AntiForgeryToken()
        <div id="alertsToast" class="alerts-toast" role="status" aria-live="polite"></div>

        <div class="alerts-table-wrap" id="alertsTableScroll">
            <table id="alertsTable" class="alerts-table">
                <thead>
                    <tr>
                        <th>Alerta</th>
                        <th>Módulo</th>
                        <th>Nivel</th>
                        <th>Fecha y hora</th>
                        <th>Estado</th>
                        <th>Envíos</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="alertsTableBody">
                    <tr class="alerts-table__loading-row">
                        <td colspan="7">Cargando alertas...</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="alerts-table-footer">
            <div class="alerts-table-footer__info" id="alertsTableInfo">Mostrando 0 registros</div>
            <div class="alerts-table-footer__controls">
                <div class="alerts-page-size">
                    <span>Mostrar</span>
                    <select id="alertsPageSize">
                        <option value="10" selected>10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                    <span>registros</span>
                </div>
                <div class="alerts-pagination">
                    <button type="button" class="alerts-btn alerts-btn--ghost alerts-btn--sm" id="alertsPrevBtn" disabled>Anterior</button>
                    <span id="alertsPageInfo">Página 1 de 1</span>
                    <button type="button" class="alerts-btn alerts-btn--ghost alerts-btn--sm" id="alertsNextBtn" disabled>Siguiente</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.alertasStockConfig = {
            listUrl: '@Url.Action("List", "AlertasStock")',
            resendUrl: '@Url.Action("Resend", "AlertasStock")'
        };
    </script>
    <script src="@Url.Content("~/Public/JS/AlertasStock/alertas-stock.js")" asp-append-version="true"></script>
}
