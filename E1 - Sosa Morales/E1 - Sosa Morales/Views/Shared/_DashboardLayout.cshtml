<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <partial name="_BrowserTab" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/Public/CSS/Dashboard/dashboard.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dashboard-body" data-auth="@(User.Identity?.IsAuthenticated == true ? "true" : "false")" data-alerts-url="@Url.Action("Notifications", "AlertasStock")">
    <div class="dashboard-layout">
        @await Html.PartialAsync("_Sidebar")

        <div class="dashboard-main">
            <div id="dashboard-content">
                @await Html.PartialAsync("_DashboardHeader")

                <main class="dashboard-content">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/Public/JS/Shared/kml-table-list.js" asp-append-version="true"></script>
    <script src="~/Public/JS/Dashboard/dashboard.js" asp-append-version="true"></script>
    <script src="~/Public/JS/Shared/global-alerts.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
