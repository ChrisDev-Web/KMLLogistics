<div id="modalForm" class="modal"><div class="modal-content"><h3 id="modalTitle">Formulario</h3><input type="hidden" id="txtId" /><div id="formFields" class="form-grid"></div><div class="modal-actions"><button id="btnCancel" type="button">Cancelar</button><button id="btnSave" class="btn-primary" type="button">Guardar</button></div></div></div>
