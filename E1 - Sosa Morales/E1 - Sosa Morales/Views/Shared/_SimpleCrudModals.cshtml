<div id="modalConfirm" class="modal"><div class="modal-content message-modal"><h3 id="confirmTitle">Confirmar accion</h3><p id="confirmText"></p><div class="modal-actions"><button id="btnCancelConfirm" type="button">Cancelar</button><button id="btnConfirm" class="btn-danger" type="button">Confirmar</button></div></div></div>
